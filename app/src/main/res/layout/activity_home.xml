<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/home_bg"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/home_fg"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>



    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/title_img"/>

        <TextView
            android:id="@+id/usernameTv"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:fontFamily="@font/nakula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="username" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

        <Button
            android:id="@+id/hostBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tribal_boots"
            android:textSize="20dp"
            android:backgroundTint="@color/green_dark"
            android:text="Create" />

        <Button
            android:id="@+id/joinBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tribal_boots"
            android:textSize="20dp"
            android:layout_marginStart="5dp"
            android:backgroundTint="@color/green_dark"
            android:text="Join" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:gravity="center"
        android:background="@drawable/round_edge_black_mask"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2"
        tools:layout_editor_absoluteX="20dp">

        <LinearLayout
            android:id="@+id/hostLL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="15dp"
            android:visibility="gone"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/roomcodeHTv"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:fontFamily="@font/bungee_font"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room Code" />

            <Button
                android:id="@+id/copyBtn"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/nakula"
                android:textColor="@color/white"
                android:backgroundTint="@color/green"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy Code" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/joinLL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="15dp">

            <EditText
                android:id="@+id/roomcodeEt"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:paddingHorizontal="20dp"
                android:fontFamily="@font/bungee_font"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/round_edge_white_mask"
                android:hint="Room code" />

            <Button
                android:id="@+id/searchBtn"
                android:backgroundTint="@color/green"
                android:textColor="@color/white"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/nakula"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/lobbyList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingBottom="15dp">

        <ListView
            android:id="@+id/playersRoomList"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="24dp"
            android:layout_height="wrap_content"/>
        <Button
            android:id="@+id/readyBtn"
            android:backgroundTint="@color/green_dark"
            android:textColor="@color/white"
            android:textSize="30dp"
            android:fontFamily="@font/tribal_boots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ready"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@android:color/white"
            android:elevation="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ProgressBar
                android:id="@+id/loadingProgress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="60dp"
                android:layout_height="60dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preparing Match"
                android:textStyle="bold"
                android:textSize="22sp"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setting up your game..."
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/loadingStatusTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Creating Match..."
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="28dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        android:id="@+id/leaf_left"
        android:layout_width="250dp"
        android:layout_height="300dp"
        android:src="@drawable/leaf_left_home"
        android:scaleType="fitXY"
        android:layout_marginStart="-20dp"
        android:layout_marginBottom="-20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <ImageView
        android:id="@+id/leaf_right"
        android:layout_width="200dp"
        android:layout_height="250dp"
        android:src="@drawable/leaf_right_home"
        android:scaleType="fitXY"
        android:layout_marginEnd="-30dp"
        android:layout_marginBottom="-30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>